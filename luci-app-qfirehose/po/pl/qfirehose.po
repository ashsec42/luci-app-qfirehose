msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Language: pl\n"

msgid "QFirehose"
msgstr "QFirehose"

msgid "Qualcomm firmware flash tool for Quectel modems. Supports firmware directory, zip and 7z packages."
msgstr "Narzędzie do flashowania firmware Qualcomm dla modemów Quectel. Obsługuje katalogi firmware, pakiety zip i 7z."

msgid "Tool Version"
msgstr "Wersja narzędzia"

msgid "Unknown"
msgstr "Nieznany"

msgid "Status"
msgstr "Status"

msgid "Idle"
msgstr "Bezczynny"

msgid "Flashing"
msgstr "Flashowanie"

msgid "Success"
msgstr "Sukces"

msgid "Failed"
msgstr "Niepowodzenie"

msgid "Error"
msgstr "Błąd"

msgid "Flashing..."
msgstr "Flashowanie..."

msgid "Firmware File"
msgstr "Plik firmware"

msgid "Upload firmware or enter path..."
msgstr "Prześlij firmware lub wprowadź ścieżkę..."

msgid "Select File"
msgstr "Wybierz plik"

msgid "Uploading..."
msgstr "Przesyłanie..."

msgid "File uploaded successfully."
msgstr "Plik przesłany pomyślnie."

msgid "File upload failed."
msgstr "Przesyłanie pliku nie powiodło się."

msgid "Supports .zip, .7z packages and firmware directories"
msgstr "Obsługuje pakiety .zip, .7z oraz katalogi firmware"

msgid "Device Settings"
msgstr "Ustawienia urządzenia"

msgid "Communication Port"
msgstr "Port komunikacyjny"

msgid "USB Device"
msgstr "Urządzenie USB"

msgid "Device Type"
msgstr "Typ urządzenia"

msgid "Auto Detect"
msgstr "Wykrywanie automatyczne"

msgid "NAND (Default)"
msgstr "NAND (Domyślny)"

msgid "eMMC"
msgstr "eMMC"

msgid "UFS"
msgstr "UFS"

msgid "Advanced Options"
msgstr "Opcje zaawansowane"

msgid "Skip MD5 Check"
msgstr "Pomiń sprawdzanie MD5"

msgid "Skip MD5 checksum verification"
msgstr "Pomiń weryfikację sumy kontrolnej MD5"

msgid "Signed Firmware"
msgstr "Podpisany firmware"

msgid "For AG215S-GLR signed firmware packages"
msgstr "Dla podpisanych pakietów firmware AG215S-GLR"

msgid "Erase All Before Download"
msgstr "Wyczyść wszystko przed pobraniem"

msgid "Erase ALL data including calibration data — modem may become permanently unusable!"
msgstr "Wyczyść WSZYSTKIE dane, w tym dane kalibracyjne — modem może stać się trwale niezdatny do użytku!"

msgid "Flash Firmware"
msgstr "Flashuj firmware"

msgid "Flash Log"
msgstr "Log flashowania"

msgid "Copy"
msgstr "Kopiuj"

msgid "Clear"
msgstr "Wyczyść"

msgid "Log copied to clipboard."
msgstr "Log skopiowany do schowka."

msgid "Please select a firmware file first."
msgstr "Proszę najpierw wybrać plik firmware."

msgid "Danger"
msgstr "Niebezpieczeństwo"

msgid "You have enabled \"Erase All Before Download\"!"
msgstr "Włączyłeś \"Wyczyść wszystko przed pobraniem\"!"

msgid "This will erase ALL data on the modem, including calibration data. The modem may become permanently unusable if calibration data is lost."
msgstr "To wyczyści WSZYSTKIE dane w modemie, w tym dane kalibracyjne. Modem może stać się trwale niezdatny do użytku, jeśli dane kalibracyjne zostaną utracone."

msgid "Are you absolutely sure you want to continue?"
msgstr "Czy na pewno chcesz kontynuować?"

msgid "I understand the risk, continue"
msgstr "Rozumiem ryzyko, kontynuuj"

msgid "Cancel"
msgstr "Anuluj"

msgid "Confirm Firmware Flash"
msgstr "Potwierdź flashowanie firmware"

msgid "Please ensure before proceeding:"
msgstr "Proszę upewnić się przed kontynuacją:"

msgid "The firmware is from official channels and compatible with your modem."
msgstr "Firmware pochodzi z oficjalnych źródeł i jest kompatybilny z Twoim modemem."

msgid "The firmware version should be higher than the current version."
msgstr "Wersja firmware powinna być wyższa niż obecna wersja."

msgid "Flashing wrong firmware can brick your modem permanently."
msgstr "Flashowanie niewłaściwego firmware może trwale uszkodzić modem."

msgid "Do not flash if you are not willing to take this risk."
msgstr "Nie flashuj, jeśli nie chcesz podjąć tego ryzyka."

msgid "Additional notes..."
msgstr "Dodatkowe uwagi..."

msgid "After flashing, use AT&F command to factory reset modem settings."
msgstr "Po flashowaniu użyj polecenia AT&F, aby przywrócić ustawienia fabryczne modemu."

msgid "mPCIe users: If modem disappears after flashing, it may have switched to USB3 mode. Use mPCIe-to-USB adapter and send AT+QUSBCFG=\"SS\",0 to switch back to USB2."
msgstr "Użytkownicy mPCIe: Jeśli modem zniknie po flashowaniu, mógł przełączyć się w tryb USB3. Użyj adaptera mPCIe-USB i wyślij AT+QUSBCFG=\"SS\",0, aby wrócić do USB2."

msgid "Continue"
msgstr "Kontynuuj"

msgid "Starting firmware flash process..."
msgstr "Rozpoczynanie procesu flashowania firmware..."

msgid "Failed to start flash process: "
msgstr "Nie udało się uruchomić procesu flashowania: "

msgid "Firmware upgrade completed successfully!"
msgstr "Aktualizacja firmware zakończona pomyślnie!"

msgid "Firmware upgrade failed."
msgstr "Aktualizacja firmware nie powiodła się."

msgid "Refresh Devices"
msgstr "Odśwież urządzenia"

msgid "Refreshing..."
msgstr "Odświeżanie..."

msgid "Reset"
msgstr "Resetuj"

msgid "Waiting for flash process to start..."
msgstr "Oczekiwanie na rozpoczęcie procesu flashowania..."

msgid "Capture USBMon Log"
msgstr "Przechwyć log USBMon"

msgid "Capture USB monitor log for debugging (-u)"
msgstr "Przechwyć log monitora USB do debugowania (-u)"

msgid "Modem Model"
msgstr "Model modemu"

msgid "Current Firmware"
msgstr "Obecny firmware"

msgid "Not detected"
msgstr "Nie wykryto"
